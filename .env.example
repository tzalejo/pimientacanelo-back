# =============================================================
# back/.env — Variables del servidor Express
# =============================================================
# Copiá este archivo a .env y completá los valores

# Puerto del servidor HTTP
PORT=3000

# --- Base de datos PostgreSQL ---
# En local: localhost
# En Docker: se sobreescribe automáticamente a "postgres" (docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=pimientacanelo

# --- Usuario admin por defecto (se crea al iniciar el servidor) ---
USERNAME=Admin
USERLASTNAME=User
PASSWORD=admin123
EMAIL=admin@example.com
PHONE=1234567890
ADDRESS=Calle Falsa 123

# --- Cloudinary (imágenes de productos) ---
# Creá una cuenta en https://cloudinary.com y completá estos valores
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET_KEY=your_secret_key
